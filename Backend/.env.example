# === SMTP Configuration (Gmail) ===
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password_without_spaces
SENDER_EMAIL=your_gmail@gmail.com

# === Password Reset URL (Update to your frontend domain) ===
PASSWORD_RESET_BASE_URL=http://localhost:3000/reset-password.html

# === JWT Configuration ===
JWT_SECRET=your_super_secret_key_12345678901234567890_at_least_50_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# === Database ===
DATABASE_URL=mysql+pymysql://root:Hema7254@127.0.0.1:3306/erp_db

# === CORS (set in backend host, e.g. Railway) ===
# Comma-separated list of exact frontend origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8080,http://localhost:8080
# Optional regex for additional origins (Cloudflare Pages/Workers are allowed by default)
CORS_ORIGIN_REGEX=https://.*\\.pages\\.dev|https://.*\\.workers\\.dev
# If true, allows all origins (credentials disabled)
CORS_ALLOW_ALL=false

