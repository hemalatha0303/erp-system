# ERP PROJECT ENVIRONMENT VARIABLES
# Copy this to .env and fill in actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/erp_db
# Example: mysql+pymysql://root:password@127.0.0.1:3306/college_erp

# ============================================
# GOOGLE GENERATIVE AI (GEMINI API)
# ============================================
# Get key from: https://aistudio.google.com/app/apikeys
# IMPORTANT: Keep this secret, never commit to git
GEMINI_API_KEY=your_api_key_here

# ============================================
# JWT SECRET (for authentication)
# ============================================
# Generate with: python -c "from secrets import token_hex; print(token_hex(32))"
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256

# ============================================
# EMAIL CONFIGURATION (for password reset)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_college_email@gmail.com
SENDER_PASSWORD=your_app_password  # Use App Passwords, not account password
# Generate Gmail App Password: https://myaccount.google.com/apppasswords

# ============================================
# APPLICATION SETTINGS
# ============================================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
DEBUG=False

# ============================================
# OPTIONAL: LOGGING
# ============================================
LOG_LEVEL=INFO
