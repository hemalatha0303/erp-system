# ERP PROJECT ENVIRONMENT VARIABLES
# Copy this to .env and fill in actual values

# ============================================
# DOCKER / DATABASE
# ============================================
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=erp_db
DATABASE_URL=mysql+pymysql://root:root@mysql:3306/erp_db

# ============================================
# GOOGLE GENERATIVE AI (GEMINI API)
# ============================================
GEMINI_API_KEY=your_api_key_here

# ============================================
# JWT SECRET
# ============================================
# Generate with: python -c "from secrets import token_hex; print(token_hex(32))"
JWT_SECRET=your_secret_key_here

# ============================================
# EMAIL CONFIGURATION
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_college_email@gmail.com
SMTP_PASSWORD=your_app_password
SENDER_EMAIL=your_college_email@gmail.com

# ============================================
# APPLICATION URLS
# ============================================
FRONTEND_URL=http://localhost
PASSWORD_RESET_BASE_URL=http://localhost/reset-password.html
